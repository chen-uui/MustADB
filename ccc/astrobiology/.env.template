# Root/runtime environment template
# Copy this file to ccc/astrobiology/.env and adjust values for your machine.

# Service ports and hosts
BACKEND_PORT=8000
BACKEND_HOST=localhost
FRONTEND_PORT=5173
FRONTEND_HOST=localhost

# Vector and retrieval services
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_TIMEOUT=30
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
T2V_HOST=localhost
T2V_PORT=9090

# Database
DB_NAME=astrobiology_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Retrieval and extraction defaults
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=1600
CHUNK_OVERLAP=400

# Local acceleration
ENABLE_CUDA=0

# Local LLM defaults
LLM_MODEL=llama3.1:8b
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# File storage
MEDIA_ROOT=./media
UPLOAD_MAX_SIZE=100MB

# Django
SECRET_KEY=change-me-before-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/astrobiology.log

# Performance
MAX_WORKERS=4
BATCH_SIZE=10
CACHE_TIMEOUT=3600

# Development-only helpers
HOT_RELOAD=True
ENABLE_CORS=True

# API request timeout in milliseconds
API_TIMEOUT=300000

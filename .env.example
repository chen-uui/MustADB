# Root/backend environment file
ENVIRONMENT=dev
DEBUG=True
SECRET_KEY=change-me-before-production
ALLOWED_HOSTS=localhost,127.0.0.1
LOG_LEVEL=INFO

# Backend service ports
BACKEND_HOST=localhost
BACKEND_PORT=8000
FRONTEND_HOST=localhost
FRONTEND_PORT=5173

# Database
DB_NAME=astrobiology_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Vector / cache / local model services
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_TIMEOUT=30
T2V_HOST=localhost
T2V_PORT=9090
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# LLM settings
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

# Retrieval / extraction settings
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=700
CHUNK_OVERLAP=80
MAX_WORKERS=4
BATCH_SIZE=10

# Frontend .env values (copy the relevant subset into
# ccc/astrobiology/astro_frontend/.env if needed)
VITE_BACKEND_HOST=localhost
VITE_BACKEND_PORT=8000
VITE_FRONTEND_HOST=localhost
VITE_FRONTEND_PORT=5173
VITE_API_TIMEOUT=300000
VITE_DEV_BEARER_TOKEN=
